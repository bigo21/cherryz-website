# Supabase — copy to .env.local and fill with your project's values.
# Project settings → API. The anon (publishable) key is safe to expose to the browser;
# quote submissions are protected by the RLS policies in supabase/migrations.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR-KEY

# Resend (emails de notification équipe + confirmation prospect). Server-side only.
RESEND_API_KEY=re_YOUR-KEY
RESEND_FROM=Cherryz <noreply@cherryz.tech>
QUOTE_NOTIFY_EMAIL=support@cherryz.tech

# Public gate (proxy.ts): "on" shows ONLY the maintenance page (every other URL → 503).
# On Vercel scope this per environment — Production (main): on ; Preview: unset/off.
MAINTENANCE_MODE=on
# Optional secret to preview the real site on a gated domain (?preview=<value>).
PREVIEW_SECRET=change-me
